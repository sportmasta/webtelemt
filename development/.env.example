# Telemt API (доступен с хоста при network_mode: host)
TELEMT_API_URL=http://127.0.0.1:9091
# TELEMT_AUTH_HEADER=Bearer <token>

# Учётные данные панели
PANEL_ADMIN_USER=admin
PANEL_ADMIN_PASSWORD=change-me

# JWT
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Порт панели (слушает 0.0.0.0)
PANEL_PORT=8080

# production — отключает /docs, проверяет JWT_SECRET при старте
PANEL_ENV=production

# CORS только для локальной разработки (vite): http://localhost:5173,http://127.0.0.1:5173
# PANEL_CORS_ORIGINS=

# Лимит попыток входа с одного IP
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=900

# HSTS (включить при HTTPS через reverse proxy)
# SECURITY_HSTS=true

# Лимит уникальных IP на пользователя (пишется в [access.user_max_unique_ips])
USER_MAX_UNIQUE_IPS=1

# PostgreSQL (webtelemt с network_mode: host подключается к 127.0.0.1:5432)
POSTGRES_PASSWORD=webtelemt
DATABASE_URL=postgresql+asyncpg://webtelemt:webtelemt@127.0.0.1:5432/webtelemt

# ЮKassa — https://yookassa.ru/developers
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Базовый URL возврата (order_id подставляется backend'ом)
YOOKASSA_RETURN_URL=http://127.0.0.1:8080

# Тариф (разовая оплата)
BILLING_PLAN_NAME=Базовый
BILLING_PLAN_PRICE_RUB=299
BILLING_PLAN_PERIOD_DAYS=30
BILLING_ORDER_TTL_MINUTES=60

# Fernet-ключ для secret at-rest (генерируется install.sh)
BILLING_CREDENTIALS_ENCRYPTION_KEY=

# Лимит создания заказов с одного IP
BILLING_ORDER_RATE_LIMIT=5
BILLING_ORDER_RATE_WINDOW_SECONDS=900
