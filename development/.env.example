# Telemt API (доступен с хоста при network_mode: host)
TELEMT_API_URL=http://127.0.0.1:9091
# TELEMT_AUTH_HEADER=Bearer <token>

# Учётные данные панели
PANEL_ADMIN_USER=admin
PANEL_ADMIN_PASSWORD=change-me

# JWT
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Порт панели (слушает 0.0.0.0)
PANEL_PORT=8080

# Лимит уникальных IP на пользователя (пишется в [access.user_max_unique_ips])
USER_MAX_UNIQUE_IPS=1
